{
  "manifest_version": 3,
  "name": "REVESTA - Assistant Immobilier Intelligent",
  "version": "1.0.0",
  "description": "Découvrez les aides immobilières directement sur les annonces LeBonCoin.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://*.leboncoin.fr/*",
    "https://mesaidesreno.beta.gouv.fr/*",
    "https://geo.api.gouv.fr/*",
    "https://admin.revesta.fr/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon-16.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    },
    "default_title": "REVESTA - Assistant Immobilier"
  },
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.leboncoin.fr/ventes_immobilieres/*",
        "https://www.leboncoin.fr/ad/ventes_immobilieres/*"
      ],
      "js": ["content-scripts/leboncoin.js"],
      "run_at": "document_end"
    }
  ],
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": ["email.html", "email-type.html"],
      "matches": ["https://www.leboncoin.fr/*"]
    }
  ]
}
